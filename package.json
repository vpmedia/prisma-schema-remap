{
  "name": "@vpmedia/prisma-schema-remap",
  "version": "1.6.0",
  "description": "Give your introspected schema.prisma sane casing conventions",
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/vpmedia/prisma-schema-remap.git"
  },
  "bin": {
    "prisma-schema-remap": "bin/cli.js"
  },
  "type": "commonjs",
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc",
    "cli": "node ./bin/cli.js",
    "format": "oxfmt --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,css}\"",
    "lint": "oxlint",
    "test": "vitest"
  },
  "dependencies": {
    "@prisma/internals": "^7.8.0",
    "chalk": "^5.6.2",
    "change-case": "^5.4.4",
    "commander": "^15.0.0",
    "js-yaml": "^5.2.1",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@types/pluralize": "0.0.33",
    "@vitest/coverage-v8": "^4.1.10",
    "globals": "^17.7.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild"
    ],
    "auditConfig": {
      "ignoreGhsas": []
    }
  }
}
