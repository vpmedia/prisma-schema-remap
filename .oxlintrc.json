{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": { "browser": true },
  "plugins": ["eslint", "jsdoc", "jsx-a11y", "oxc", "promise", "react-perf", "react", "typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "nursery": "off",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "rules": {
    "capitalized-comments": "off",
    "complexity": "off",
    "consistent-type-assertions": "off",
    "consistent-type-definitions": "off",
    "consistent-type-imports": "off",
    "curly": "off",
    "default-case": "off",
    "eqeqeq": "off",
    "explicit-function-return-type": "off",
    "explicit-module-boundary-types": "off",
    "filename-case": "off",
    "func-style": "off",
    "guard-for-in": "off",
    "id-length": "off",
    "init-declarations": "off",
    "max-lines-per-function": "off",
    "max-lines": "off",
    "max-params": "off",
    "max-statements": "off",
    "new-for-builtins": "off",
    "no-array-reduce": "off",
    "no-array-sort": "off",
    "no-async-await": "off",
    "no-console": "off",
    "no-continue": "off",
    "no-explicit-any": "off",
    "no-extra-boolean-cast": "off",
    "no-extraneous-class": "off",
    "no-implicit-coercion": "off",
    "no-inline-comments": "off",
    "no-magic-numbers": "off",
    "no-non-null-assertion": "off",
    "no-null": "off",
    "no-optional-chaining": "off",
    "no-param-reassign": "off",
    "no-plusplus": "off",
    "no-prototype-builtins": "off",
    "no-require-imports": "off",
    "no-rest-spread-properties": "off",
    "no-shadow": "off",
    "no-sparse-arrays": "off",
    "no-ternary": "off",
    "no-undefined": "off",
    "no-unneeded-ternary": "off",
    "no-unused-vars": "off",
    "no-use-before-define": "off",
    "no-useless-escape": "off",
    "no-var-requires": "off",
    "parameter-properties": "off",
    "prefer-const": "off",
    "prefer-destructuring": "off",
    "prefer-for-of": "off",
    "prefer-module": "off",
    "prefer-node-protocol": "off",
    "prefer-template": "off",
    "prefer-top-level-await": "off",
    "require-param": "off",
    "require-returns": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "switch-case-braces": "off",
    "text-encoding-identifier-case": "off",
    "yoda": "off",
  }
}
